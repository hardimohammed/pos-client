# ============================================================
#  pos-client — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  Vite only reads variables prefixed with VITE_.
# ============================================================

# Backend API base URL — point at your deployed Render backend.
VITE_API_URL=https://your-backend.onrender.com/api/v1

# Socket.io server URL — same backend, no /api/v1 suffix.
VITE_SOCKET_URL=https://your-backend.onrender.com

# Sentry error tracking (optional — leave blank to disable)
VITE_SENTRY_DSN=
